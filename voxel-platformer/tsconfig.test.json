{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noEmit": false,
    "outDir": ".tmp/test-build",
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": true
  },
  "include": [
    "src/engine/voxel/chunk.ts",
    "src/engine/voxel/chunk-manager.ts",
    "src/engine/voxel/level-serializer.ts",
